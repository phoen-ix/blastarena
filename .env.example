# Docker
COMPOSE_PROJECT_NAME=blast-arena
APP_EXTERNAL_PORT=8080

# Database
DB_HOST=db
DB_PORT=3306
DB_NAME=blast_arena
DB_USER=blast_user
DB_PASSWORD=change_me_in_production
DB_ROOT_PASSWORD=change_root_password
DB_EXTERNAL_PORT=3307

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6380

# Auth
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
EMAIL_PEPPER=change_this_to_a_random_64_char_hex_string
TOTP_ENCRYPTION_KEY=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=BlastArena

# App
APP_URL=http://localhost:8080
LOG_LEVEL=info
NODE_ENV=development

# Game
GAME_TICK_RATE=20
MAX_ROOMS=50
MAX_PLAYERS_PER_ROOM=8
BOMB_TIMER_SECONDS=3
POWERUP_DROP_CHANCE=0.3

# Rate Limits (requests per window)
RATE_LIMIT_LOGIN=5
RATE_LIMIT_REGISTER=3
RATE_LIMIT_API=100
