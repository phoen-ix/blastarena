{
  "name": "@blast-arena/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "copy-locales": "node scripts/copy-locales.cjs",
    "prebuild": "npm run copy-locales",
    "build": "npm run build --workspace=@blast-arena/shared && tsc",
    "start": "node dist/index.js",
    "predev": "npm run copy-locales",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "cd .. && npx jest --config tests/backend/jest.config.ts"
  },
  "dependencies": {
    "@blast-arena/shared": "*",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "esbuild": "^0.27.4",
    "express": "^4.21.0",
    "i18next": "^25.10.10",
    "i18next-fs-backend": "^2.6.1",
    "ioredis": "^5.4.1",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^6.9.14",
    "otpauth": "^9.5.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^6.4.15",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
